{
  "name": "@storybook/addon-css-viewer",
  "version": "10.3.3",
  "description": "Display css/less file content linked to story's component in a TAB.",
  "keywords": [
    "storybook-addon", "css", "less", "viewer", "display", "tab", "storybook-addons"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Peanuts-83/storybook-css-addon.git"
  },
  "resolveJsonModule": true,
  "type": "module",
  "license": "MIT",
  "author": "Thomas Ranque aka Peanuts-83 <tranque@free.fr>",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/preview.d.ts",
      "import": "./dist/preview.js",
      "default": "./dist/preview.js"
    },
    "./constant": {
      "types": "./dist/constants.d.ts",
      "import": "./dist/constants.js",
      "default": "./dist/constants.js"
    },
    "./preset": {
      "types": "./dist/preset.d.ts",
      "import": "./dist/preset.js",
      "default": "./dist/preset.js"
    },
    "./manager": {
      "types": "./dist/manager.d.ts",
      "import": "./dist/manager.js",
      "default": "./dist/manager.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts",
    "package.json"
  ],
  "scripts": {
    "build": "tsup",
    "publish": "npm publish",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
  },
  "peerDependencies": {
    "storybook": "10.3.3",
    "react": ">=18.0.0 <19.0.0",
    "react-dom": ">=18.0.0 <19.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bundler": {
    "exportEntries": [
    ],
    "managerEntries": [
      "./src/manager.tsx"
    ],
    "previewEntries": [
      "./src/preview.ts",
      "./src/index.ts" 
    ],
    "nodeEntries": [
      "./src/preset.ts"
    ]
  },
  "storybook": {
    "displayName": "Css Viewer",
    "supportedFrameworks": [
      "react angular any"
    ],
    "icon": "https://avatars.githubusercontent.com/u/74671565?v=4"
  }
}
