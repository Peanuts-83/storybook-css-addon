{
  "name": "@storybook/addon-css-viewer",
  "version": "10.0.0-alpha1",
  "description": "Display css/less file content linked to story's component in a TAB.",
  "keywords": [
    "storybook-addon", "css", "less", "viewer", "display", "tab", "storybook-addons"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Peanuts-83/storybook-css-addon.git"
  },
  "resolveJsonModule": true,
  "type": "module",
  "license": "MIT",
  "author": "Peanuts-83 thomas ranque <tranque@free.fr>",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./preview": {
      "types": "./dist/index.d.ts",
      "default": "./dist/preview.js"
    },
    "./constant": {
      "types": "./dist/index.d.ts",
      "default": "./src/constants.ts"
    },
    "./preset": "./dist/preset.js",
    "./manager": "./dist/manager.js",
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "README.md",
    "*.js",
    "*.d.ts"
  ],
  "scripts": {
    "build": "tsup",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "dependencies": {
    "@storybook/icons": "^1.2.10",
    "styled-components": "^6.1.17"
  },
  "devDependencies": {
    "@storybook/react": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@storybook/addon-docs": "^10.0.0",
    "storybook": "^10.0.0",
    "@types/node": "^18.15.0",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "auto": "^11.1.1",
    "boxen": "^7.1.1",
    "dedent": "^1.5.1",
    "npm-run-all2": "^6.2.3",
    "prettier": "^3.3.3",
    "prompts": "^2.4.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-tsconfig-paths": "6.1.1",
    "zx": "^7.2.3"
  },
  "peerDependencies": {
    "storybook": "^9.0.0 || ^10.0.0",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "bundler": {
    "exportEntries": [
    ],
    "managerEntries": [
      "./src/manager.tsx"
    ],
    "previewEntries": [
      "./src/preview.ts",
      "./src/index.ts" 
    ],
    "nodeEntries": [
      "./src/preset.ts"
    ]
  },
  "storybook": {
    "displayName": "Css Viewer",
    "supportedFrameworks": [
      "react angular any"
    ],
    "icon": "https://avatars.githubusercontent.com/u/74671565?v=4"
  }
}
