{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "baseUrl": ".",
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "incremental": false,
    "isolatedModules": true,
    "jsx": "react-jsx",                           // "react" anciennement
    "lib": ["esnext", "dom", "dom.iterable"],
    "module": "esnext",                           // "commonjs" anciennement
    "moduleResolution": "bundler",                   // explicite / new
    "noImplicitAny": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "target": "esnext",
    "resolveJsonModule": true
  },
  "include": ["./src/**/*", "tsup.config.ts" ]
}
