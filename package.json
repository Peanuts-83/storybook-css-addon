{
  "name": "storybook-addon-css-viewer-workspace",
  "description": "Display css/less file content linked to story's component in a TAB.",
  "private": true,
  "workspaces": [
    "packages/css-viewer-addon",
    "packages/css-viewer-docs"
  ],
  "type": "module",
  "author": "thomas ranque <tranque@free.fr>",
  "scripts": {
    "clean": "rm -rf dist",
    "watch": "yarn run addon:build && yarn run docs:start",
    "test": "echo \"Error: no test specified\" && exit 1",
    "addon:build": "cd packages/css-viewer-addon/ && tsup",
    "addon:publish": "cd packages/css-viewer-addon/ && npm publish",
    "docs:build": "yarn workspace css-viewer-docs run build-storybook",
    "docs:start": "yarn workspace css-viewer-docs run storybook"
  },
  "devDependencies": {
    "@storybook/addon-docs": "^10.0.0",
    "@storybook/react": "^10.0.0",
    "@storybook/react-vite": "^10.0.0",
    "@types/node": "^18.15.0",
    "@types/react": "^18.2.65",
    "@types/react-dom": "^18.2.21",
    "@vitejs/plugin-react": "^4.2.1",
    "auto": "^11.1.1",
    "boxen": "^7.1.1",
    "dedent": "^1.5.1",
    "npm-run-all2": "^6.2.3",
    "prettier": "^3.3.3",
    "prompts": "^2.4.2",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "storybook": "^10.0.0",
    "tsup": "^8.2.4",
    "typescript": "^5.5.4",
    "vite": "^5.3.5",
    "vite-tsconfig-paths": "6.1.1",
    "zx": "^7.2.3"
  },
  "peerDependencies": {
    "storybook": "^9.0.0 || ^10.0.0",
    "react": ">=18.0.0 <20.0.0",
    "react-dom": ">=18.0.0 <20.0.0"
  },
  "storybook": {
    "displayName": "Css Viewer",
    "supportedFrameworks": [
      "react angular"
    ],
    "icon": "https://avatars.githubusercontent.com/u/74671565?v=4"
  }
}
